PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/vm_metrics
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SASL_MECHANISM=
KAFKA_SSL_CA_LOCATION=
KAFKA_SSL_CA_PEM=
KAFKA_TOPIC=vm.metric-samples.v1
KAFKA_DLQ_TOPIC=vm.metric-samples.dlq.v1
KAFKA_CONSUMER_GROUP=vm-metrics-processors
LOG_LEVEL=INFO
ENVIRONMENT=local
MAX_PAGE_SIZE=1000
MAX_INGEST_BATCH_SIZE=1000
CPU_ALERT_THRESHOLD_PERCENT=90
MEMORY_ALERT_THRESHOLD_PERCENT=90
RAW_RETENTION_DAYS=7
AGGREGATE_RETENTION_DAYS=90
MAX_RAW_QUERY_HOURS=24
MAX_FUTURE_SKEW_SECONDS=300
AUTO_CREATE_SCHEMA=true
