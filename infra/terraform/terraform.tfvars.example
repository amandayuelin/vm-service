name_prefix   = "vm-service"
app_name      = "vm-service"
github_repo   = "amandayuelin/vm-service"
github_branch = "main"
app_region    = "nyc"
region        = "nyc1"
vpc_ip_range  = "10.20.0.0/16"

data_droplet_image = "ubuntu-24-04-x64"
data_droplet_size  = "s-2vcpu-2gb"

# Optional: add SSH access for debugging.
# ssh_key_fingerprints = ["<your-ssh-key-fingerprint-or-id>"]
# ssh_allowed_cidrs    = ["<your-public-ip>/32"]

postgres_db   = "vm_metrics"
postgres_user = "vm_metrics"

kafka_topic           = "vm.metric-samples.v1"
kafka_dlq_topic       = "vm.metric-samples.dlq.v1"
kafka_partition_count = 12
max_kafka_heap_mb     = 768

api_instance_count    = 1
worker_instance_count = 1

app_instance_size_slug    = "apps-s-1vcpu-1gb"
worker_instance_size_slug = "apps-s-1vcpu-1gb"

max_ingest_batch_size = 1000
max_page_size         = 1000
